# ============================================================
#  Sports Engine — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#
#  Railway users: set these in your service's Variables tab.
#  Required keys are marked with [REQUIRED].
#  Optional keys show their default value after the "=" sign.
# ============================================================

# ── Telegram ─────────────────────────────────────────────────────────────────
# [REQUIRED] Your Telegram Bot API token (from @BotFather)
TOKEN=

# [OPTIONAL] Telegram channel ID for daily broadcast alerts (e.g. -1001234567890)
ALERTS_CHANNEL_ID=

# ── Sports / Fixtures APIs ────────────────────────────────────────────────────
# [RECOMMENDED] API-Sports / API-Football key for live soccer fixtures
# https://api-sports.io  →  get your free key at https://dashboard.api-football.com
API_SPORTS_KEY=

# [OPTIONAL] Football-Data.org token — alternative/supplementary soccer data source
# https://www.football-data.org  (falls back to API_SPORTS_KEY when not set)
FOOTBALL_DATA_TOKEN=

# [OPTIONAL] Sportradar API key — richer NBA/NFL/MLB stats (OffRtg, DefRtg, ERA, etc.)
# https://developer.sportradar.com
SPORTRADAR_API_KEY=

# [OPTIONAL] Sportradar access level: "trial" (default) or "" for a production licence
SPORTRADAR_ACCESS=trial

# ── AI / Vision (Google Gemini) ──────────────────────────────────────────────
# [OPTIONAL] Google Gemini API key — enables:
#   1. Automatic reading of parlay ticket photos (Gemini Vision).
#   2. AI-powered match analysis (/analisis command).
#   3. Sports betting Q&A (/pregunta command).
#   4. Top-picks summary (/ai_picks command).
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# [OPTIONAL] Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ── Odds / Betting APIs ───────────────────────────────────────────────────────
# [OPTIONAL] The Odds API key — enables live bookmaker odds in the auto-scanner
# https://the-odds-api.com  (free tier: 500 requests/month)
ODDS_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# [OPTIONAL] PostgreSQL connection string — enables persistent fixture storage.
# Railway: add a PostgreSQL plugin and link DATABASE_URL via Variable Reference.
# When not set the bot falls back to CSV storage.
DATABASE_URL=

# [OPTIONAL] Alternative PostgreSQL URL name (checked if DATABASE_URL is absent)
POSTGRES_URL=

# ── Auto-Scanner Tuning ───────────────────────────────────────────────────────
# [OPTIONAL] Seconds between full auto-scan cycles (default: 300 = 5 min)
AUTO_SCAN_INTERVAL=300

# [OPTIONAL] Minimum EV% to emit an alert — avoids marginal-value spam (default: 5.0)
AUTO_SCAN_MIN_EV=5.0

# [OPTIONAL] Seconds to suppress a duplicate alert (deduplication TTL, default: 3600)
AUTO_SCAN_DEDUP_TTL=3600

# ── Parlay Calibration ────────────────────────────────────────────────────────
# [OPTIONAL] Rolling window for parlay calibration (default: 200 recent legs)
PARLAY_CAL_WINDOW=200

# [OPTIONAL] EWMA decay factor for calibration (default: 0.95; lower = more recency bias)
PARLAY_EWMA_DECAY=0.95

# ── Runtime ───────────────────────────────────────────────────────────────────
# [OPTIONAL] Python logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# [OPTIONAL] HTTP port for Railway health checks (Railway sets this automatically)
PORT=8080
